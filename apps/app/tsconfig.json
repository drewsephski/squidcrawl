{
  "extends": "@deepcrawl/typescript-config/nextjs.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/.source": ["./.source/index.ts"],
      "@/*": ["./*"],
      "@deepcrawl/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@deepcrawl/ui/*": ["../../packages/ui/src/*"],
      "@deepcrawl/auth/*": ["../../packages/auth/src/*"],
      "@deepcrawl/types/*": ["../../packages/types/src/*"],
      "squidcrawl": ["../../packages/sdks/js-ts/src/index.ts"],
      "squidcrawl/types": ["../../packages/sdks/js-ts/src/types-public.ts"],
      "squidcrawl/schemas": ["../../packages/sdks/js-ts/src/schemas-public.ts"],
      "squidcrawl/types/utils": [
        "../../packages/sdks/js-ts/src/types-utils.ts"
      ],
      "@deepcrawl/contracts/*": ["../../packages/contracts/src/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
